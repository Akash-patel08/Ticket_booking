# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── NextAuth ────────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── Redis (for seat hold TTL & concurrency locks) ────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Email (Nodemailer — Gmail example) ──────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="TicketBooking <noreply@ticketbooking.com>"

# ─── Seat Hold Configuration ─────────────────────────────────────────
SEAT_HOLD_TTL_SECONDS=600

# ─── Waitlist Offer Configuration ────────────────────────────────────
WAITLIST_OFFER_TTL_MINUTES=30
